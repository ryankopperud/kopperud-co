---
interface Props {
  heading?: string;
  description?: string;
  compact?: boolean;
}

const {
  heading = 'Stay in the loop',
  description = 'Occasional creative updates, marketing insights, and thoughtful writing. No spam, no fluff. Just the good stuff.',
  compact = false,
} = Astro.props;
---

{compact ? (
  <div class="newsletter-compact">
    {heading && <p class="newsletter-compact__heading">{heading}</p>}
    <form
      action="https://homelessryank.us12.list-manage.com/subscribe/post?u=f263abfcf223697bdf5332ff6&amp;id=17ae78766a&amp;f_id=00ad64e9f0"
      method="POST"
      class="newsletter-compact__form"
    >
      <input type="hidden" name="u" value="f263abfcf223697bdf5332ff6" />
      <input type="hidden" name="id" value="17ae78766a" />
      <input type="hidden" name="f_id" value="00ad64e9f0" />
      <div aria-hidden="true" style="position: absolute; left: -5000px;">
        <input type="text" name="b_f263abfcf223697bdf5332ff6_17ae78766a" tabindex="-1" value="" />
      </div>
      <input
        type="email"
        name="EMAIL"
        placeholder="your@email.com"
        required
        aria-label="Email address"
        class="newsletter-compact__input"
      />
      <button type="submit" class="newsletter-compact__button" aria-label="Subscribe">
        Subscribe
        <span aria-hidden="true">→</span>
      </button>
    </form>
  </div>
) : (
  <section class="section-dark section-padding-sm">
    <div class="container-narrow text-center">
      <h2 class="text-3xl sm:text-4xl mb-4">{heading}</h2>
      <p class="text-[var(--color-surface)]/60 mb-8 max-w-lg mx-auto">
        {description}
      </p>
      <form
        action="https://homelessryank.us12.list-manage.com/subscribe/post?u=f263abfcf223697bdf5332ff6&amp;id=17ae78766a&amp;f_id=00ad64e9f0"
        method="POST"
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      >
        <input type="hidden" name="u" value="f263abfcf223697bdf5332ff6" />
        <input type="hidden" name="id" value="17ae78766a" />
        <input type="hidden" name="f_id" value="00ad64e9f0" />
        <!-- Honeypot anti-spam field -->
        <div aria-hidden="true" style="position: absolute; left: -5000px;">
          <input type="text" name="b_f263abfcf223697bdf5332ff6_17ae78766a" tabindex="-1" value="" />
        </div>
        <input
          type="email"
          name="EMAIL"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 bg-white/10 border border-white/20 text-[var(--color-surface)] placeholder:text-white/40 focus:outline-none focus:border-[var(--color-brand-yellow)] transition-colors text-sm"
        />
        <button type="submit" class="btn-primary whitespace-nowrap">
          Subscribe
        </button>
      </form>
    </div>
  </section>
)}

<style>
  .newsletter-compact {
    width: 100%;
  }

  .newsletter-compact__heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    margin-bottom: 0.625rem;
    text-align: center;
  }

  .newsletter-compact__form {
    display: flex;
    gap: 0;
    width: 100%;
    border: 1.5px solid var(--color-ink);
    background: white;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .newsletter-compact__form:focus-within {
    border-color: var(--color-brand-yellow);
    box-shadow: 4px 4px 0 var(--color-ink);
  }

  .newsletter-compact__input {
    flex: 1;
    min-width: 0;
    padding: 0.875rem 1rem;
    background: transparent;
    border: 0;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    outline: none;
  }

  .newsletter-compact__input::placeholder {
    color: var(--color-ink-muted);
  }

  .newsletter-compact__button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0 1.25rem;
    background-color: var(--color-brand-yellow);
    color: var(--color-ink);
    border: 0;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .newsletter-compact__button:hover {
    background-color: var(--color-brand-gold);
  }

  .newsletter-compact__button span {
    transition: transform 0.2s ease;
  }

  .newsletter-compact__button:hover span {
    transform: translateX(3px);
  }

  @media (max-width: 480px) {
    .newsletter-compact__form {
      flex-direction: column;
    }
    .newsletter-compact__button {
      padding: 0.875rem 1rem;
      justify-content: center;
      border-top: 1.5px solid var(--color-ink);
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const shows = [
  {
    title: 'The What If? Podcast',
    description: 'A comedy podcast that asks strange, hilarious, and difficult questions. Co-hosted with Spencer Wirth-Davis. Live performances across Minnesota and California.',
    stats: 'Comedy',
    links: [
      { label: 'Spotify', href: 'https://open.spotify.com/show/whatifpodcast' },
      { label: 'Apple Podcasts', href: 'https://podcasts.apple.com/us/podcast/the-what-if-podcast' },
    ]
  },
  {
    title: 'The SaaS Brand Strategy Show',
    description: 'Business growth, marketing strategy, and category creation for B2B and B2C leaders. Co-hosted with Dustin Robertson and Mike Geraci. Created by DRMG.',
    stats: 'Business & Strategy',
    links: [
      { label: 'Apple Podcasts', href: 'https://podcasts.apple.com/us/podcast/the-saas-brand-strategy-show/id1586314229' },
    ]
  },
  {
    title: 'Finding Quantum Quest',
    description: 'A lost media podcast about an obscure and nearly forgotten film. Co-hosted by Big Cats, produced by Ryan & Sam McCullough. Features interviews with actors, filmmakers, and even NASA employees.',
    stats: 'Documentary',
    links: []
  },
  {
    title: 'ConversionCast / The Lead Generation',
    description: 'Origin stories and marketing lessons from entrepreneurs. Originally created for Leadpages in 2017, later evolved into a video podcast format covering entrepreneurship and growth.',
    stats: 'Entrepreneurship',
    links: []
  }
];
---

<BaseLayout title="Podcasting | Ryan Kopperud" description="500+ episodes. 1,000+ five-star reviews. Millions of downloads. Four podcast projects spanning comedy, business strategy, lost media, and entrepreneurship.">

  <!-- Hero -->
  <section class="section-padding">
    <div class="container-wide">
      <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
        <div class="max-w-2xl flex-1">
          <span class="accent-bar mb-6"></span>
          <h1 class="text-5xl sm:text-6xl md:text-7xl mb-8">Podcasting</h1>
          <p class="text-xl text-[var(--color-ink-light)] leading-relaxed">
            Four shows. 500+ episodes. 1,000+ five-star reviews. Millions of downloads. From comedy to business strategy to documentary storytelling — every show starts with the same instinct: find a great story and tell it well.
          </p>
        </div>
        <div class="w-72 md:w-80 shrink-0">
          <img src="/images/whatif-podcast.webp" alt="The What If? Podcast studio" loading="eager" fetchpriority="high" class="w-full aspect-[4/3] object-cover rounded-sm shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-[var(--color-surface-warm)] border-y border-[var(--color-border)]">
    <div class="container-wide">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <p class="stat-number">500+</p>
          <p class="text-sm text-[var(--color-ink-muted)] mt-2 font-medium">Episodes</p>
        </div>
        <div>
          <p class="stat-number">1,000+</p>
          <p class="text-sm text-[var(--color-ink-muted)] mt-2 font-medium">Five-Star Reviews</p>
        </div>
        <div>
          <p class="stat-number">M+</p>
          <p class="text-sm text-[var(--color-ink-muted)] mt-2 font-medium">Downloads</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Shows -->
  <section class="section-padding">
    <div class="container-wide">
      <span class="accent-bar mb-6"></span>
      <h2 class="text-3xl sm:text-4xl mb-12">The shows</h2>
      <div class="space-y-12">
        {shows.map(show => (
          <div class="card">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-1">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-gold)] mb-2">{show.stats}</p>
                <h3 class="font-display text-2xl md:text-3xl mb-4">{show.title}</h3>
                <p class="text-[var(--color-ink-muted)] leading-relaxed mb-4">{show.description}</p>
                {show.links.length > 0 && (
                  <div class="flex flex-wrap gap-3">
                    {show.links.map(link => (
                      <a href={link.href} target="_blank" rel="noopener noreferrer" class="btn-outline text-xs py-2 px-4">
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark section-padding-sm">
    <div class="container-narrow text-center">
      <h2 class="text-3xl sm:text-4xl mb-6">Want me on your podcast?</h2>
      <p class="text-[var(--color-surface)]/60 mb-8 max-w-lg mx-auto">
        I love being a guest. Let's talk marketing, storytelling, creativity, entrepreneurship, or whatever you've got.
      </p>
      <a href="/contact" class="btn-primary">
        Book me
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>

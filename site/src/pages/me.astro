---
import '../styles/global.css';
import Newsletter from '../components/Newsletter.astro';

const title = 'Ryan Kopperud — All Links';
const description = 'Marketer, podcaster, musician, and writer based in Minneapolis. Find every link, listen, and read in one place.';
const ogImage = '/images/ryan-bio-square.webp';
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://kopperud.co');
const ogImageURL = new URL(ogImage, Astro.site || 'https://kopperud.co').href;

const featured = [
  {
    eyebrow: 'Marketing',
    title: 'Work with me',
    description: 'Strategy and creative for brands that want to mean something.',
    href: '/marketing',
    cta: 'Inquire',
    icon: 'spark',
  },
  {
    eyebrow: 'Writing',
    title: 'Essays & notes',
    description: 'What I’m thinking about marketing, craft, and the work.',
    href: '/writing',
    cta: 'Read',
    icon: 'pen',
  },
  {
    eyebrow: 'Podcasting',
    title: 'On the mic',
    description: 'Conversations, shows, and the craft behind them.',
    href: '/podcasting',
    cta: 'Listen',
    icon: 'mic',
  },
  {
    eyebrow: 'Music',
    title: 'Songs & records',
    description: 'My latest album and everything else I’ve released.',
    href: '/music',
    cta: 'Listen',
    icon: 'wave',
  },
];

const socials = [
  { name: 'Instagram', href: 'https://www.instagram.com/ryankopperud/', icon: 'instagram' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/in/ryankopperud/', icon: 'linkedin' },
  { name: 'X (Twitter)', href: 'https://x.com/ryankopperud', icon: 'x' },
  { name: 'YouTube', href: 'https://www.youtube.com/@ryankopperud', icon: 'youtube' },
  { name: 'Facebook', href: 'https://www.facebook.com/ryankopperud/', icon: 'facebook' },
  { name: 'Spotify', href: 'https://open.spotify.com/artist/02WrQ3bFUrPs8GLBRt2ATl', icon: 'spotify' },
];

const email = 'ryan@kopperud.co';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ryankopperud" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="me-body">
    <div class="me-bg" aria-hidden="true"></div>

    <a href="/" class="me-wordmark">
      <span class="me-wordmark__dot" aria-hidden="true"></span>
      <span class="me-wordmark__text">Kopperud &amp; Co.</span>
    </a>

    <main class="me-page">
      <!-- Bio -->
      <header class="me-bio fade-in">
        <div class="me-headshot">
          <img
            src="/images/ryan-bio-square.webp"
            alt="Ryan Kopperud"
            width="280"
            height="280"
            loading="eager"
          />
        </div>
        <h1 class="me-name">Ryan Kopperud</h1>
        <p class="me-roles">Marketer · Writer · Podcaster · Musician</p>
        <p class="me-location">
          <span class="me-location__dot" aria-hidden="true"></span>
          Minneapolis, Minnesota
        </p>
        <p class="me-tagline">
          I make stuff and write about it. Marketer by day, podcaster, musician,
          and writer the rest of the time.
        </p>
      </header>

      <!-- Subscribe -->
      <section class="me-subscribe fade-in" aria-label="Email subscribe">
        <Newsletter compact={true} heading="Hear from me when cool things happen" />
      </section>

      <div class="me-divider" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>

      <!-- Featured cards -->
      <section class="me-featured fade-in" aria-label="Featured links">
        <div class="me-grid">
          {featured.map((item) => (
            <a href={item.href} class="me-card">
              <div class="me-card__icon" aria-hidden="true">
                {item.icon === 'mic' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="2" width="6" height="12" rx="3" />
                    <path d="M5 10v2a7 7 0 0 0 14 0v-2" />
                    <line x1="12" y1="19" x2="12" y2="22" />
                  </svg>
                )}
                {item.icon === 'wave' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12h2l2-7 3 14 3-10 3 7 2-4h3" />
                  </svg>
                )}
                {item.icon === 'pen' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 19l7-7 3 3-7 7-3-3z" />
                    <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18" />
                    <path d="M2 2l7.586 7.586" />
                    <circle cx="11" cy="11" r="2" />
                  </svg>
                )}
                {item.icon === 'spark' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2v6M12 16v6M2 12h6M16 12h6M5 5l4 4M15 15l4 4M5 19l4-4M15 9l4-4" />
                  </svg>
                )}
              </div>
              <div class="me-card__body">
                <span class="me-card__eyebrow">{item.eyebrow}</span>
                <h2 class="me-card__title">{item.title}</h2>
                <p class="me-card__desc">{item.description}</p>
              </div>
              <span class="me-card__cta" aria-hidden="true">
                {item.cta}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          ))}
        </div>
        <a href="/contact" class="me-contact-cta">
          Contact me
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </section>

      <!-- Music platforms -->
      <section class="me-platforms fade-in" aria-label="Listen on">
        <p class="me-platforms__label">Listen on</p>
        <div class="me-platforms__row">
          <a
            href="https://open.spotify.com/artist/02WrQ3bFUrPs8GLBRt2ATl"
            class="me-platform"
            target="_blank"
            rel="noopener"
            aria-label="Spotify"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24Zm5.5 17.3a.75.75 0 0 1-1 .25c-2.8-1.7-6.3-2.1-10.4-1.2a.75.75 0 1 1-.3-1.5c4.5-1 8.4-.5 11.5 1.4.4.2.5.7.2 1.05Zm1.5-3.4a.94.94 0 0 1-1.3.3c-3.2-2-8-2.55-11.85-1.4a.94.94 0 1 1-.55-1.8c4.4-1.3 9.7-.7 13.4 1.6.45.27.6.85.3 1.3Zm.13-3.55C15.3 8 8.7 7.8 5.05 8.95a1.13 1.13 0 1 1-.65-2.15C8.7 5.5 16 5.7 20.4 8.3a1.13 1.13 0 0 1-1.27 1.85Z"/></svg>
            <span>Spotify</span>
          </a>
          <a
            href="https://music.apple.com/us/artist/ryan-kopperud/1445715427"
            class="me-platform"
            target="_blank"
            rel="noopener"
            aria-label="Apple Music"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M23.997 6.124c0-.738-.065-1.47-.24-2.19-.317-1.31-1.062-2.31-2.18-3.043C21.003.517 20.373.285 19.7.164c-.517-.093-1.038-.135-1.564-.15-.04-.003-.083-.01-.124-.014H5.988c-.152.01-.303.017-.455.026C4.786.07 4.043.15 3.34.428 2.004.958 1.04 1.88.475 3.208c-.192.448-.292.925-.363 1.408-.056.392-.088.785-.1 1.18 0 .032-.007.062-.01.093v12.223c.01.14.017.283.027.424.05.815.154 1.624.497 2.373.65 1.42 1.738 2.353 3.234 2.802.42.127.856.187 1.293.228.555.053 1.11.06 1.667.06h11.03a17 17 0 0 0 1.57-.1c.823-.106 1.597-.35 2.296-.81.84-.553 1.472-1.287 1.88-2.208.186-.42.293-.87.37-1.324.113-.675.138-1.358.137-2.04-.002-3.8 0-7.595-.003-11.393zm-6.423 3.99v5.712c0 .417-.058.827-.244 1.206-.29.59-.76.962-1.388 1.14-.35.1-.706.157-1.07.173-.95.045-1.773-.6-1.943-1.536-.142-.773.227-1.624 1.038-2.022.32-.158.66-.252 1.002-.335.38-.092.764-.176 1.138-.285.27-.08.44-.278.49-.567.01-.067.018-.135.018-.203 0-1.875 0-3.75-.002-5.625 0-.06-.008-.12-.02-.18-.033-.16-.144-.258-.3-.3a.97.97 0 0 0-.494-.008c-.795.16-1.59.327-2.386.49l-2.685.55-1.6.33a.4.4 0 0 0-.032.01c-.21.072-.32.23-.334.45-.003.06-.003.12-.003.178-.002 2.684 0 5.37-.002 8.055 0 .417-.06.827-.244 1.207-.29.59-.76.96-1.388 1.14-.35.1-.706.157-1.07.173-.95.045-1.773-.6-1.943-1.537-.14-.773.228-1.624 1.038-2.022.322-.158.662-.252 1.003-.335.38-.092.764-.176 1.138-.285.27-.08.44-.277.49-.567.012-.068.018-.135.018-.203 0-3.495 0-6.99-.002-10.483 0-.1.016-.197.043-.294.07-.25.246-.396.487-.46.302-.08.606-.133.912-.193l2.722-.542 2.92-.585 2.56-.513c.333-.066.665-.134.997-.202.434-.088.69.196.69.535l.002.1z"/></svg>
            <span>Apple Music</span>
          </a>
        </div>
      </section>

      <div class="me-divider" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>

      <!-- Socials -->
      <section class="me-socials fade-in" aria-label="Social profiles">
        <p class="me-socials__label">Follow me</p>
        <ul class="me-socials__list">
          {socials.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener" aria-label={s.name} class="me-social">
                {s.icon === 'instagram' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/></svg>
                )}
                {s.icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm7 0h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.5c0-1.3-.02-3-1.83-3-1.83 0-2.12 1.43-2.12 2.9V21h-4V9Z"/></svg>
                )}
                {s.icon === 'x' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.829l4.713 6.231 5.448-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>
                )}
                {s.icon === 'youtube' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1c.4-1.9.5-3.8.5-5.8a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"/></svg>
                )}
                {s.icon === 'facebook' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z"/></svg>
                )}
                {s.icon === 'spotify' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24Zm5.5 17.3a.75.75 0 0 1-1 .25c-2.8-1.7-6.3-2.1-10.4-1.2a.75.75 0 1 1-.3-1.5c4.5-1 8.4-.5 11.5 1.4.4.2.5.7.2 1.05Zm1.5-3.4a.94.94 0 0 1-1.3.3c-3.2-2-8-2.55-11.85-1.4a.94.94 0 1 1-.55-1.8c4.4-1.3 9.7-.7 13.4 1.6.45.27.6.85.3 1.3Zm.13-3.55C15.3 8 8.7 7.8 5.05 8.95a1.13 1.13 0 1 1-.65-2.15C8.7 5.5 16 5.7 20.4 8.3a1.13 1.13 0 0 1-1.27 1.85Z"/></svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Email + footer -->
      <footer class="me-footer fade-in">
        <button type="button" class="me-email" data-email={email} aria-label="Copy email address">
          {email}
        </button>
        <p class="me-copyright">© {new Date().getFullYear()} Kopperud &amp; Co.</p>
      </footer>
    </main>

    <div id="me-toast" class="me-toast" role="status" aria-live="polite">Email copied</div>

    <script is:inline>
      (function () {
        const btn = document.querySelector('.me-email');
        const toast = document.getElementById('me-toast');
        if (!btn || !toast) return;
        btn.addEventListener('click', async () => {
          const email = btn.getAttribute('data-email');
          try {
            await navigator.clipboard.writeText(email);
          } catch (e) {
            const ta = document.createElement('textarea');
            ta.value = email;
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); } catch (_) {}
            document.body.removeChild(ta);
          }
          toast.classList.add('me-toast--show');
          setTimeout(() => toast.classList.remove('me-toast--show'), 1600);
        });
      })();
    </script>

    <style is:global>
      :root {
        color-scheme: light;
      }
      html, body {
        background-color: var(--color-surface-warm);
      }
    </style>

    <style>
      .me-body {
        position: relative;
        min-height: 100svh;
        font-family: var(--font-body);
        color: var(--color-ink);
      }

      /* Subtle paper-texture background */
      .me-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        background-color: var(--color-surface-warm);
        background-image:
          radial-gradient(circle at 1px 1px, rgba(26, 26, 26, 0.06) 1px, transparent 0);
        background-size: 22px 22px;
      }
      .me-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
          ellipse at top,
          rgba(245, 197, 24, 0.08),
          transparent 60%
        );
      }

      .me-wordmark {
        position: absolute;
        top: 1.25rem;
        left: 1.5rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-ink);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .me-wordmark:hover { color: var(--color-brand-gold); }
      .me-wordmark__dot {
        width: 10px;
        height: 10px;
        background: var(--color-brand-yellow);
        border-radius: 50%;
      }
      .me-wordmark__text {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 1.125rem;
        letter-spacing: -0.03em;
      }

      .me-page {
        max-width: 560px;
        margin: 0 auto;
        padding: 5rem 1.5rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
      }

      /* Bio */
      .me-bio {
        text-align: center;
        animation-delay: 0s;
      }
      .me-headshot {
        width: 140px;
        height: 140px;
        margin: 0 auto 1.5rem;
        border: 4px solid var(--color-brand-yellow);
        box-shadow: 8px 8px 0 var(--color-ink);
        background: white;
        overflow: hidden;
      }
      .me-headshot img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 28%;
        transform: scale(1.45);
        transform-origin: center 30%;
      }
      .me-name {
        font-family: var(--font-display);
        font-size: clamp(2.25rem, 6vw, 3rem);
        font-weight: 500;
        letter-spacing: -0.025em;
        line-height: 1;
        margin: 0 0 0.625rem;
        color: var(--color-ink);
      }
      .me-roles {
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        color: var(--color-ink-light);
        margin: 0 0 0.5rem;
      }
      .me-location {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8125rem;
        color: var(--color-ink-muted);
        margin: 0 0 1.125rem;
      }
      .me-location__dot {
        width: 7px;
        height: 7px;
        background: var(--color-brand-yellow);
        border-radius: 50%;
        box-shadow: 0 0 0 3px rgba(245, 197, 24, 0.18);
      }
      .me-tagline {
        font-size: 0.9375rem;
        line-height: 1.55;
        color: var(--color-ink-light);
        max-width: 440px;
        margin: 0 auto;
      }

      /* Subscribe wrapper */
      .me-subscribe { animation-delay: 0.08s; }

      /* Divider */
      .me-divider {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.625rem;
      }
      .me-divider span {
        width: 5px;
        height: 5px;
        background: var(--color-ink-muted);
        opacity: 0.4;
        border-radius: 50%;
      }
      .me-divider span:nth-child(2) {
        background: var(--color-brand-yellow);
        opacity: 1;
      }

      /* Featured cards */
      .me-featured { animation-delay: 0.16s; }
      .me-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.875rem;
      }
      .me-card {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        padding: 1.25rem 1.25rem 1.125rem;
        background: white;
        border: 1px solid var(--color-border);
        text-decoration: none;
        color: var(--color-ink);
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
        min-height: 168px;
      }
      .me-card:hover {
        border-color: var(--color-brand-yellow);
        transform: translateY(-2px);
        box-shadow: 6px 6px 0 var(--color-ink);
      }
      .me-card__icon {
        width: 32px;
        height: 32px;
        color: var(--color-ink);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .me-card__icon svg { width: 24px; height: 24px; }
      .me-card__body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .me-card__eyebrow {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-ink-muted);
      }
      .me-card__title {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 500;
        line-height: 1.15;
        letter-spacing: -0.015em;
        margin: 0;
        color: var(--color-ink);
      }
      .me-card__desc {
        font-size: 0.8125rem;
        line-height: 1.45;
        color: var(--color-ink-muted);
        margin: 0;
      }
      .me-card__cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--color-ink);
        margin-top: auto;
      }
      .me-card__cta svg { transition: transform 0.2s ease; }
      .me-card:hover .me-card__cta svg { transform: translateX(4px); }

      /* Contact CTA */
      .me-contact-cta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        margin-top: 1.25rem;
        padding: 1rem 1.25rem;
        background: var(--color-brand-yellow);
        color: var(--color-ink);
        font-family: var(--font-body);
        font-weight: 600;
